#compdef dfy
# SPDX-License-Identifier: GPL-3.0-or-later
# Zsh tab completion for the dfy command. Place this file in a directory on
# $fpath, e.g. /usr/local/share/zsh/site-functions/_dfy.

_dfy_resolve_dir() {
  local dir="${DFY_DIR:-}"
  if [[ -z "$dir" ]]; then
    local config_file="${XDG_CONFIG_HOME:-${HOME}/.config}/dotlify/config"
    if [[ -f "$config_file" ]]; then
      local line
      line="$(grep -m1 '^dir=' "$config_file" 2>/dev/null || true)"
      if [[ -n "$line" ]]; then
        dir="${line#dir=}"
        dir="${dir/#\~/$HOME}"
        [[ -d "$dir" ]] || dir=""
      fi
    fi
  fi
  print "${dir:-${HOME}/.dotfiles}"
}

_dfy_list_packages() {
  local dir="$1"
  [[ -d "$dir" ]] || return
  local entry name
  while IFS= read -r -d '' entry; do
    name="${entry##*/}"
    [[ "$name" == profiles || "$name" == .* ]] && continue
    print "$name"
  done < <(find "$dir" -mindepth 1 -maxdepth 1 -type d -print0 2>/dev/null | sort -z)
}

_dfy_list_profiles() {
  local dir="$1/profiles"
  [[ -d "$dir" ]] || return
  local f name
  while IFS= read -r -d '' f; do
    name="${f##*/}"
    print "${name%.txt}"
  done < <(find "$dir" -maxdepth 1 -name '*.txt' -print0 2>/dev/null | sort -z)
}

_dfy() {
  local state line context
  typeset -A opt_args

  local -a subcommands
  subcommands=(
    'apply:apply packages from the dotfiles repo'
    'remove:remove installed packages'
    'adopt:adopt existing dotfiles into the repo'
    'list:list available packages'
    'info:show a package README'
    'create:scaffold a new package'
    'status:show link status of packages'
    'doctor:check runtime dependencies'
    'update:update Dotlify to the latest version'
    'uninstall:remove Dotlify from this system'
    'help:show help'
  )

  local -a global_opts
  global_opts=(
    '(--help -h)'{--help,-h}'[show help]'
    '(--version -V)'{--version,-V}'[show version]'
    '--no-color[disable color output]'
    '--dry-run[show what would be done without doing it]'
    '(--yes -y)'{--yes,-y}'[answer yes to all prompts]'
    '--profile[activate a profile]:profile:->profile_names'
    '--dir[dotfiles directory]:directory:_files -/'
    '--lang[language]:lang:(en es)'
  )

  _arguments -C \
    "${global_opts[@]}" \
    '1:subcommand:->subcommand' \
    '*:args:->args'

  case "$state" in
    subcommand)
      _describe 'subcommand' subcommands
      ;;
    profile_names)
      local dots_dir
      dots_dir="$(_dfy_resolve_dir)"
      local -a profs
      profs=("${(@f)$(_dfy_list_profiles "$dots_dir")}")
      compadd -a profs
      ;;
    args)
      case "$words[2]" in
        apply | remove | adopt | info)
          local dots_dir
          dots_dir="$(_dfy_resolve_dir)"
          local -a pkgs
          pkgs=("${(@f)$(_dfy_list_packages "$dots_dir")}")
          compadd -a pkgs
          ;;
      esac
      ;;
  esac
}

(( ${+CURRENT} )) && _dfy "$@"
