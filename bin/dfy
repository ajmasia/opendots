#!/usr/bin/env bash
# SPDX-License-Identifier: GPL-3.0-or-later
set -euo pipefail

# Require bash >= 4 before sourcing anything that uses bash 4 features.
if ((BASH_VERSINFO[0] < 4)); then
  printf 'dfy requires bash >= 4 (found: %s). Please upgrade.\n' "${BASH_VERSION}" >&2
  exit 4
fi

# Resolve DFY_LIB from this binary's real path so symlinks into PATH work.
# Uses plain readlink (portable; -f is GNU/Linux-only) with an iterative loop.
# Skipped when DFY_LIB is already set (e.g. by Nix wrapProgram or tests).
if [[ -z "${DFY_LIB:-}" ]]; then
  _dfy_resolve() {
    local f="$1"
    [[ "$f" == /* ]] || f="$PWD/$f"
    local i=0 link
    while [[ -L "$f" && $((i++)) -lt 40 ]]; do
      link="$(readlink "$f")"
      [[ "$link" == /* ]] || link="$(dirname "$f")/$link"
      f="$link"
    done
    printf '%s' "$(cd "$(dirname "$f")" && pwd -P)/$(basename "$f")"
  }
  DFY_LIB="$(dirname "$(_dfy_resolve "$0")")/../lib"
  unset -f _dfy_resolve
  export DFY_LIB
fi

# shellcheck source=/dev/null
source "${DFY_LIB}/theme.sh"
# shellcheck source=/dev/null
source "${DFY_LIB}/ui.sh"
# shellcheck source=/dev/null
source "${DFY_LIB}/version.sh"
# shellcheck source=/dev/null
source "${DFY_LIB}/os.sh"
# shellcheck source=/dev/null
source "${DFY_LIB}/i18n.sh"
# shellcheck source=/dev/null
source "${DFY_LIB}/args.sh"
# shellcheck source=/dev/null
source "${DFY_LIB}/repo.sh"
# shellcheck source=/dev/null
source "${DFY_LIB}/profile.sh"
# shellcheck source=/dev/null
source "${DFY_LIB}/cmd_help.sh"
# shellcheck source=/dev/null
source "${DFY_LIB}/cmd_link.sh"
# shellcheck source=/dev/null
source "${DFY_LIB}/cmd_unlink.sh"
# shellcheck source=/dev/null
source "${DFY_LIB}/cmd_adopt.sh"
# shellcheck source=/dev/null
source "${DFY_LIB}/cmd_list.sh"
# shellcheck source=/dev/null
source "${DFY_LIB}/cmd_status.sh"
# shellcheck source=/dev/null
source "${DFY_LIB}/cmd_doctor.sh"
# shellcheck source=/dev/null
source "${DFY_LIB}/cmd_update.sh"
# shellcheck source=/dev/null
source "${DFY_LIB}/cmd_uninstall.sh"
# shellcheck source=/dev/null
source "${DFY_LIB}/cmd_info.sh"
# shellcheck source=/dev/null
source "${DFY_LIB}/cmd_create.sh"
# shellcheck source=/dev/null
source "${DFY_LIB}/cmd_delete.sh"
# shellcheck source=/dev/null
source "${DFY_LIB}/config.sh"
# shellcheck source=/dev/null
source "${DFY_LIB}/cmd_init.sh"
# shellcheck source=/dev/null
source "${DFY_LIB}/cmd_config.sh"
# shellcheck source=/dev/null
source "${DFY_LIB}/notify.sh"

# Pre-load English so error messages during flag parsing have MSG_* values.
i18n::load "en"

# Parse global flags; fills DFY_SUBCMD, DFY_SUBCMD_ARGS, and other globals.
args::parse_global "$@"

# Populate missing config keys with their defaults on every startup.
config::write_defaults

# Resolve language: --lang flag > config file > en.
_dfy_lang="${DFY_LANG:-$(i18n::configured_lang)}"
_dfy_lang="${_dfy_lang:-en}"

# Reload locale with the resolved language.
i18n::load "$_dfy_lang"

if [[ "${DFY_SHOW_VERSION:-0}" == "1" ]]; then
  cmd_help::show_version
  exit 0
fi

if [[ "${DFY_SHOW_HELP:-0}" == "1" ]]; then
  if [[ -n "${DFY_SUBCMD:-}" ]]; then
    cmd_help::run_subcmd "$DFY_SUBCMD"
  else
    cmd_help::run
  fi
  exit 0
fi
if [[ -z "${DFY_SUBCMD:-}" ]]; then
  cmd_help::run
  exit 0
fi

args::dispatch "$DFY_SUBCMD" "${DFY_SUBCMD_ARGS[@]+"${DFY_SUBCMD_ARGS[@]}"}"
notify::check
