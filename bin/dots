#!/usr/bin/env bash
# SPDX-License-Identifier: GPL-3.0-or-later
set -euo pipefail

# Require bash >= 4 before sourcing anything that uses bash 4 features.
if ((BASH_VERSINFO[0] < 4)); then
  printf 'dots requires bash >= 4 (found: %s). Please upgrade.\n' "${BASH_VERSION}" >&2
  exit 4
fi

# Resolve DOTS_LIB from this binary's real path so symlinks into PATH work.
DOTS_LIB="$(dirname "$(readlink -f "$0")")/../lib"
export DOTS_LIB

# shellcheck source=/dev/null
source "${DOTS_LIB}/theme.sh"
# shellcheck source=/dev/null
source "${DOTS_LIB}/ui.sh"
# shellcheck source=/dev/null
source "${DOTS_LIB}/version.sh"
# shellcheck source=/dev/null
source "${DOTS_LIB}/i18n.sh"
# shellcheck source=/dev/null
source "${DOTS_LIB}/args.sh"
# shellcheck source=/dev/null
source "${DOTS_LIB}/os.sh"
# shellcheck source=/dev/null
source "${DOTS_LIB}/repo.sh"
# shellcheck source=/dev/null
source "${DOTS_LIB}/profile.sh"
# shellcheck source=/dev/null
source "${DOTS_LIB}/cmd_help.sh"
# shellcheck source=/dev/null
source "${DOTS_LIB}/cmd_install.sh"
# shellcheck source=/dev/null
source "${DOTS_LIB}/cmd_remove.sh"
# shellcheck source=/dev/null
source "${DOTS_LIB}/cmd_adopt.sh"
# shellcheck source=/dev/null
source "${DOTS_LIB}/cmd_list.sh"
# shellcheck source=/dev/null
source "${DOTS_LIB}/cmd_status.sh"
# shellcheck source=/dev/null
source "${DOTS_LIB}/cmd_doctor.sh"

# Pre-load English so error messages during flag parsing have MSG_* values.
i18n::load "en"

# Parse global flags; fills DOTS_SUBCMD, DOTS_SUBCMD_ARGS, and other globals.
args::parse_global "$@"

# Resolve language: --lang flag > config file > en.
_dots_lang="${DOTS_LANG:-$(i18n::configured_lang)}"
_dots_lang="${_dots_lang:-en}"

# Reload locale with the resolved language.
i18n::load "$_dots_lang"

if [[ "${DOTS_SHOW_VERSION:-0}" == "1" ]]; then
  cmd_help::show_version
  exit 0
fi

if [[ "${DOTS_SHOW_HELP:-0}" == "1" || -z "${DOTS_SUBCMD:-}" ]]; then
  cmd_help::run
  exit 0
fi

args::dispatch "$DOTS_SUBCMD" "${DOTS_SUBCMD_ARGS[@]+"${DOTS_SUBCMD_ARGS[@]}"}"
